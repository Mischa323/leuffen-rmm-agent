#!/bin/sh
# Runs after an upgrade (DSM uses preupgrade/postupgrade instead of pre/postinst).
# Re-apply the same best-effort setup as postinst. Must always exit 0.
set +e
PKG="LeuffenRMM"
TARGET="${SYNOPKG_PKGDEST:-/var/packages/${PKG}/target}"
VAR="${SYNOPKG_PKGVAR:-/var/packages/${PKG}/var}"

mkdir -p "${VAR}" 2>/dev/null
if [ -f "${TARGET}/rmm_config.json" ]; then
    cp -f "${TARGET}/rmm_config.json" "${VAR}/rmm_config.json" 2>/dev/null
    chmod 600 "${VAR}/rmm_config.json" 2>/dev/null
fi

if [ -d /etc/sudoers.d ] && [ -w /etc/sudoers.d ]; then
    for u in "${SYNOPKG_PKGNAME}" "${PKG}"; do
        [ -n "$u" ] || continue
        id "$u" >/dev/null 2>&1 && \
            echo "$u ALL=(ALL) NOPASSWD: ALL" >> /etc/sudoers.d/leuffen-rmm 2>/dev/null
    done
    [ -f /etc/sudoers.d/leuffen-rmm ] && chmod 440 /etc/sudoers.d/leuffen-rmm 2>/dev/null
fi
exit 0
