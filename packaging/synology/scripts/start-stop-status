#!/bin/sh
# Leuffen RMM Synology agent — DSM service control (start/stop/status).
#
# DSM runs this with the package's environment set: $SYNOPKG_PKGDEST is the
# install target, $SYNOPKG_PKGVAR the persistent writable area. We launch the
# pure-stdlib agent with the Synology Python3 interpreter (declared as an
# install dependency) and keep config + logs in the var area.

PKG="LeuffenRMM"
TARGET="${SYNOPKG_PKGDEST:-/var/packages/${PKG}/target}"
VAR="${SYNOPKG_PKGVAR:-/var/packages/${PKG}/var}"
PIDFILE="${VAR}/agent.pid"
LOG="${VAR}/agent.log"

# Export so the agent stores device id / config / secret in the persistent area.
export RMM_DATA_DIR="${VAR}"

find_python() {
    # Any installed DSM Python 3 package works (official Python3.9, or a
    # SynoCommunity Python3.10+). Names/paths vary, so probe PATH then the
    # package dirs, matching both "python3" and versioned "python3.N".
    for p in python3 /usr/local/bin/python3 /usr/bin/python3; do
        if command -v "$p" >/dev/null 2>&1; then echo "$p"; return; fi
    done
    for p in /var/packages/Python3*/target/usr/bin/python3 \
             /var/packages/Python3*/target/bin/python3 \
             /var/packages/Python3*/target/usr/bin/python3.[0-9] \
             /var/packages/Python3*/target/usr/bin/python3.[0-9][0-9] \
             /var/packages/Python3*/target/bin/python3.[0-9] \
             /var/packages/Python3*/target/bin/python3.[0-9][0-9]; do
        [ -x "$p" ] && { echo "$p"; return; }
    done
    echo ""
}

start_daemon() {
    mkdir -p "${VAR}"
    PYTHON="$(find_python)"
    if [ -z "${PYTHON}" ]; then
        echo "python3 not found (install the Synology Python3 package)" >>"${LOG}"
        exit 1
    fi
    echo "$(date) starting as user=$(id -un 2>/dev/null) python=${PYTHON}" >>"${LOG}"
    # The package runs as a non-root user (DSM 7 won't install a root package), so
    # run the agent through sudo when postinst's grant is in place — it needs root
    # for Active Backup (synowebapi), reboot and remote shell. Without sudo it
    # still runs and reports core metrics.
    if sudo -n true 2>/dev/null; then
        echo "$(date) sudo OK -> running agent as root" >>"${LOG}"
        sudo -n RMM_DATA_DIR="${VAR}" "${PYTHON}" "${TARGET}/syno_agent.py" >>"${LOG}" 2>&1 &
    else
        echo "$(date) no sudo -> running unprivileged (core metrics only)" >>"${LOG}"
        "${PYTHON}" "${TARGET}/syno_agent.py" >>"${LOG}" 2>&1 &
    fi
    echo $! > "${PIDFILE}"
}

stop_daemon() {
    if [ -f "${PIDFILE}" ]; then
        PID="$(cat "${PIDFILE}")"
        kill "${PID}" 2>/dev/null
        sudo -n kill "${PID}" 2>/dev/null
        rm -f "${PIDFILE}"
    fi
    # The agent may be running as root via sudo; make sure it's gone.
    sudo -n pkill -f "${TARGET}/syno_agent.py" 2>/dev/null || pkill -f "${TARGET}/syno_agent.py" 2>/dev/null
}

daemon_status() {
    [ -f "${PIDFILE}" ] && kill -0 "$(cat "${PIDFILE}")" 2>/dev/null
}

case "$1" in
    start)
        daemon_status || start_daemon
        exit 0
        ;;
    stop)
        stop_daemon
        exit 0
        ;;
    status)
        if daemon_status; then exit 0; else exit 3; fi
        ;;
    *)
        exit 1
        ;;
esac
